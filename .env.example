# API Configuration
# Replace with your actual API endpoint
# Expected API endpoint: POST /analyze
# Expected request format: FormData with 'file' (resume file) and 'job_description' (job description file)
# Expected response format: JSON with structure { groq_response: { match_score, missing_skills, improvement_suggestions, interview_preparation_tips } }
# NOTE: Use localhost or 127.0.0.1 instead of 0.0.0.0 (0.0.0.0 is server-only address)
REACT_APP_API_ENDPOINT=http://localhost:3000/analyze_marksheet
